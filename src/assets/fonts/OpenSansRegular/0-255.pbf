    <style>
      .user-mention[href$="/el-gros"] {
        color: var(--color-user-mention-fg);
        background-color: var(--bgColor-attention-muted, var(--color-attention-subtle));
        border-radius: 2px;
        margin-left: -2px;
        margin-right: -2px;
      }
      .user-mention[href$="/el-gros"]:before,
      .user-mention[href$="/el-gros"]:after {
